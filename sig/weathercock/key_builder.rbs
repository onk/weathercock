class Weathercock::KeyBuilder
  def initialize: (namespace: String, klass: untyped) -> void

  def base: (Symbol) -> String

  def total: (String) -> String

  def bucket: (String, :hours | :days, Time) -> String
            | (String, :months, Date) -> String

  def window_keys: (String, :hours | :days | :months, Integer) -> Array[String]

  def union_dest: (String, :hours | :days | :months, Integer) -> String
end
